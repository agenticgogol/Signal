# LLM Provider: anthropic | openai | groq
LLM_PROVIDER=anthropic

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (optional)
OPENAI_API_KEY=sk-...

# Groq (optional)
GROQ_API_KEY=gsk_...

# OpenRouter (optional)
OPENROUTER_API_KEY=sk-or-...

# LangSmith (optional — for tracing)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=GenAI Analyst OS

# Mock mode — set true to skip real API calls in tests
MOCK_LLM=false

# Max articles to fetch per source per crawl (3 for first run, 20 for daily)
CRAWL_MAX_PER_SOURCE=3

# Logging format: json (default) | pretty (colourised dev output)
LOG_FORMAT=json

# Arize Phoenix (local — no account needed)
PHOENIX_ENABLED=true          # set to false to disable
# PHOENIX_PORT=6006           # default port; change if in use

# Arize Cloud (optional — sign up at app.arize.com)
ARIZE_API_KEY=
ARIZE_SPACE_ID=

# LangSmith (optional — sign up at smith.langchain.com)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls__...

# Your Supabase account email (pre-fills the dashboard sidebar)
ACCOUNT_EMAIL=

# Supabase
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# App URLs
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Application-layer encryption for user-stored API keys
# Use a stable 32-byte secret. Example: openssl rand -base64 32
APP_ENCRYPTION_KEY=

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
